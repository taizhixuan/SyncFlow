# ───────────────────────────────────────────────────────────
# SyncFlow — .gitignore
# ───────────────────────────────────────────────────────────

# ── Dependencies ──
node_modules/
.pnp
.pnp.js
.pnp.cjs
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
jspm_packages/

# ── Build output / compiled ──
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.svelte-kit/
.turbo/
.vite/
*.tsbuildinfo
coverage/
*.local

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Environment / secrets ──
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ── Editors / IDEs ──
# WebStorm / IntelliJ
.idea/
*.iml
# VS Code
.vscode/
!.vscode/extensions.json
# Misc editor cruft
*.swp
*.swo
*~

# ── OS files ──
.DS_Store
Thumbs.db
desktop.ini

# ── Testing / tooling caches ──
.eslintcache
.stylelintcache
playwright-report/
test-results/
.playwright-mcp/
.nyc_output/

# ── Local verification screenshots ──
/phase*.png

# ── Docker / local data volumes ──
docker-data/
pgdata/
miniodata/

# ── Claude Code / AI assistant artifacts ──
CLAUDE.md
.claude/
.serena/
.codegraph/

# ── Internal planning & design docs (local-only) ──
planning/

# ── Original project spec (planning artifact, kept local) ──
syncboard-realtime-whiteboard.md
/.superpowers/
docs/
