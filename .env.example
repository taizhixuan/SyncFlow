# ─────────────────────────────────────────────────────────────
# SyncFlow — environment template. Copy to `.env` and adjust.
# Config is validated at boot (Joi); missing/invalid values fail fast.
# ─────────────────────────────────────────────────────────────

# ── Runtime ──
NODE_ENV=development
API_PORT=3000
# Comma-separated list of allowed browser origins for CORS.
WEB_ORIGIN=http://localhost:5173

# ── PostgreSQL ──
POSTGRES_USER=syncflow
POSTGRES_PASSWORD=syncflow_dev_pw
POSTGRES_DB=syncflow
# Used by Prisma from the host machine. Host port is 5433 (compose maps 5433->5432)
# to avoid clashing with a locally-installed PostgreSQL on 5432.
# From inside compose, the api service uses host `postgres` and port 5432.
DATABASE_URL=postgresql://syncflow:syncflow_dev_pw@localhost:5433/syncflow?schema=public

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Object storage (MinIO locally / S3 in prod) ──
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=syncflow-assets
S3_ACCESS_KEY=syncflow
S3_SECRET_KEY=syncflow_dev_pw
S3_FORCE_PATH_STYLE=true

# ── Auth (used from Phase 2/Auth onward) ──
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# ── Web (Vite, build-time) ──
VITE_API_URL=/api/v1
